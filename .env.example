COMPOSE_PROJECT_NAME=telegram-bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
CONFIG_PATH=./config
DOCKER_SOCKET_PATH=/var/run/docker.sock
BOT_ACTIONS_CONFIG=/app/config/actions.example.yaml
BOT_HOST_ACTION_SOCKET=/var/run/telegram-bot/host-actions.sock
BOT_HOST_ACTIONS_PORT=8787
BOT_HOST_ACTION_ENDPOINT=host.docker.internal:${BOT_HOST_ACTIONS_PORT}
HOST_ACTIONS_CONFIG=${CONFIG_PATH}/host-actions.yaml